    interval: 86400
    url: "https://core.telegram.org/resources/cidr.txt"
    path: ./ruleset/telegram_ip.txt

  twitter:
    type: http
    behavior: domain
    format: mrs
    interval: 86400
    url: "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/twitter.mrs"
